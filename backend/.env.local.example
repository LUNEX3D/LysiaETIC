# Yerel geliştirme — kopyalayın:  copy .env.local.example .env.local
# Sunucudaki .env dosyasına dokunmadan sadece kendi bilgisayarınızda geçerlidir.

NODE_ENV=development
CORS_ALLOW_LAN=true

# Hetzner MongoDB (yerel PC — Hetzner firewall'da ev/ofis IP'nizi 27017'ye açın)
# MONGO_URI=mongodb://KULLANICI:SIFRE@HETZNER_IP:27017/lysia?authSource=admin

# Redis yoksa BullMQ/WB AI kuyruğu kullanılmaz (6379 konsol hatası olmaz)
# REDIS_URL=redis://127.0.0.1:6379

# İsteğe bağlı: hosts dosyasında dashtock.com → 127.0.0.1 kullanıyorsanız
# CORS_EXTRA_ORIGINS=http://dashtock.com:3000
