# ─── LysiaETIC Frontend — Environment Variables ───
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
# ⚠️ .env dosyasını ASLA git'e commit etmeyin!

# OpenSSL Legacy Provider (Node.js 17+ uyumluluğu)
NODE_OPTIONS=--openssl-legacy-provider

# API URL (development'ta .env.development'tan override edilir; production'da boş = /api proxy)
REACT_APP_API_URL=http://localhost:5000
# Canlı site (e-posta linkleri, yasal sayfalar)
# REACT_APP_SITE_URL=https://pazaryonet.com

# Environment
REACT_APP_ENV=development

# Google OAuth Client ID
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
