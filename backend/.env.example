# ─── LysiaETIC Backend — Environment Variables ───
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
# ⚠️ .env dosyasını ASLA git'e commit etmeyin!

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/ecommerce?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Credential Encryption (32 byte = 64 hex karakter)
# Oluşturmak için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Resend Email Configuration
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=LysiaETIC <noreply@yourdomain.com>
APP_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
