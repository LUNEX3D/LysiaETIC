# ─── LysiaETIC Backend — Environment Variables ───
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
# ⚠️ .env dosyasını ASLA git'e commit etmeyin!

# Server
PORT=5000
# Sunucuda: NODE_ENV=production | Kendi PC'nizde: backend/.env.local oluşturun (aşağıya bakın)
NODE_ENV=development

# MongoDB kotası dolunca yerel geliştirmede arka plan cron'larını kapat (stok/AI/radar yazmaz)
# DISABLE_BACKGROUND_JOBS=true

# ─── Yerel geliştirme (.env.local — git'e gitmez) ───
# backend/.env.local.example dosyasını .env.local olarak kopyalayın.
# .env içinde NODE_ENV=production olsa bile .env.local bunu development yapar.

# CORS — Ek origin'ler (virgülle ayırın). Örn: http://192.168.1.108:3000
# CORS_EXTRA_ORIGINS=
# Production'da LAN IP'lerini otomatik kabul ETME (varsayılan: NODE_ENV=production ise kapalı)
# Gerekirse: CORS_ALLOW_LAN=true

# Sipariş API: tarih parametresi yoksa varsayılan kaç gün geriye (1–365, varsayılan 7)
# ORDER_DEFAULT_WINDOW_DAYS=7

# Ana sayfa arka plan sync penceresi (gün, varsayılan 7)
# DASHBOARD_SYNC_WINDOW_DAYS=7

# Sunucu tarafı pazaryeri sipariş cron (ms, varsayılan 60000 = 1 dk)
# ORDER_SYNC_CRON_MS=60000
# Ana sayfa dashboard önbellek (ms, varsayılan 20000)
# DASHBOARD_CACHE_MS=20000
# Yeni sipariş e-postası (varsayılan açık)
# NEW_ORDER_EMAIL_ENABLED=true
# Gönderim hatasında tekrar dene (varsayılan kapalı — aynı siparişe tekrar mail gitmesin)
# NEW_ORDER_EMAIL_RETRY_ON_FAIL=false
# ORDER_SYNC_CRON_DAYS=7
# DISABLE_ORDER_SYNC_CRON=true

# ÇiçekSepeti sipariş sync max gün (varsayılan 45)
# CS_MAX_SYNC_DAYS=45
# CICEKSEPETI_MIN_INTERVAL_MS=5500

# Opsiyonel — uzun ürün senkronları için BullMQ (ayrıca `npm run worker:sync` çalıştırın)
# REDIS_URL=redis://127.0.0.1:6379
# SYNC_USE_BULLMQ=true

# Web mağaza — PayTR şifreleme (opsiyonel, yoksa JWT_SECRET kullanılır)
# STORE_ENCRYPTION_KEY=

# ProductMapping: listelenmiş TY/HB/N11 kanallarında categoryId zorunlu (varsayılan: kapalı)
# PRODUCT_MAPPING_REQUIRE_CATEGORY_ID=true

# Hepsiburada kategori çekimi: varsayılan HB+HX (ürün kataloğu). Kampanya ağacı HC dahil etmek için:
# HB_CATEGORY_INCLUDE_HC=true

# MongoDB

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-separate-refresh-token-secret-change-this

# Credential Encryption (32 byte = 64 hex karakter)
# Oluşturmak için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Resend Email Configuration
# Resend — https://resend.com/domains → dashtock.com ekleyin (SPF + DKIM DNS)
# Domain doğrulanmadan gerçek kullanıcılara mail GİTMEZ (403 validation_error).
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=Dashtock <info@dashtock.com>
REPLY_TO_EMAIL=info@dashtock.com
MAIL_DOMAIN=dashtock.com
APP_DOMAIN=dashtock.com
APP_URL=https://dashtock.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# PayTR Direkt API — https://dev.paytr.com/direkt-api/direkt-api-1-adim
# Mağaza Paneli → Bilgi + Destek'ten Direkt API yetkisi isteyin
PAYTR_MERCHANT_ID=your-merchant-id
PAYTR_MERCHANT_KEY=your-merchant-key
PAYTR_MERCHANT_SALT=your-merchant-salt
PAYTR_OK_URL=https://dashtock.com/payment/success
PAYTR_FAIL_URL=https://dashtock.com/payment/failed
PAYTR_NOTIFY_URL=https://dashtock.com/api/paytr/callback
PAYTR_TEST_MODE=1
# iframe (önerilen) veya direct
# iframe = PayTR ödeme ekranı (önerilen). direct = panelde Direkt API yetkisi gerekir
PAYTR_FLOW=iframe

# QNB eSolutions E-Fatura SOAP API
# Doküman: https://www.qnbesolutions.com.tr/api-docs-tr-final.html
# Test ortamı başvuru: https://www.qnbesolutions.com.tr/destek/api-teknik
QNB_ERP_CODE=ESC31309

# e-Fatura & e-İrsaliye (SOAP connectorService)
QNB_EFATURA_TEST_WSDL=https://erpefaturatest1.qnbesolutions.com.tr/efatura/ws/connectorService?wsdl
QNB_EFATURA_TEST2_WSDL=https://erpefaturatest2.qnbesolutions.com.tr/efatura/ws/connectorService?wsdl
QNB_USER_TEST_WSDL=https://erpefaturatest1.qnbesolutions.com.tr/efatura/ws/userService?wsdl
# QNB_EFATURA_PROD_WSDL=  (canlı endpoint — entegrasyon tamamlanınca QNB'den alınacak)
# QNB_USER_PROD_WSDL=

# e-Arşiv (SOAP EarsivWebService)
QNB_EARSIV_TEST_WSDL=https://earsivtest.qnbesolutions.com.tr/earsiv/ws/EarsivWebService?wsdl
QNB_EARSIV_USER_TEST_WSDL=https://connectortest.qnbesolutions.com.tr/connector/ws/userService?wsdl
# QNB_EARSIV_PROD_WSDL=
# QNB_EARSIV_USER_PROD_WSDL=

# QNB e-Arşiv Credentials
# PDF indirme ve fatura sorgulama için gerekli
# Test: VKN formatında (örn: 7610650466)
# Production: Gerçek kullanıcı adı ve şifre
QNB_EARSIV_USERNAME=
QNB_EARSIV_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# LysiaRadar PRO V2 — 4 Kanal Çapraz Doğrulama API Anahtarları
# ═══════════════════════════════════════════════════════════════
# ⚠️ Hepsi OPSİYONEL! Boş bırakırsan simülasyon modunda çalışır.

# OpenAI — GPT-4 AI Özetleri
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Lysia Agent sohbeti — ücretsiz yerel LLM (Ollama) veya yukarıdaki OpenAI
# https://ollama.com — `ollama serve` sonra `ollama pull llama3.2`
# LYSIA_LLM_PROVIDER=auto
# auto: önce Ollama (USE_OLLAMA veya OLLAMA_BASE_URL), yoksa OPENAI_API_KEY
# USE_OLLAMA=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════
# Birim ekonomisi admin paneli — aylık bulut maliyeti tahmini (TRY)
# UNIT_ECONOMICS_AWS_TRY=2500          # EC2/ECS, ALB, S3, egress vb.
# UNIT_ECONOMICS_MONGODB_TRY=1500      # MongoDB Atlas (M10/M20 vb.)
# UNIT_ECONOMICS_INFRA_TRY=4000        # Eski tek kalem (aws+mongo yoksa %62.5 / %37.5 bölünür)

# AI Operatör (LysiaBrain) Kontrol Anahtarları
# ═══════════════════════════════════════════════════════════════
# AI Background Worker — Analiz cache (5dk) + opsiyonel otonom döngü (10dk)
# Test/staging ortamlarında otomatik aksiyonu kapatmak için:
#   AI_WORKER_ENABLED=true            (default: production'da açık, test'te kapalı)
#   AI_OPERATOR_CYCLE_ENABLED=false   (sadece analiz cache çalışsın, otonom aksiyon yok)
# AI_WORKER_ENABLED=true
# AI_OPERATOR_CYCLE_ENABLED=true

# Legacy /api/ai/* (eski intelligentEngine) — aktif UI artık /api/ai-engine + /api/ai-chat kullanıyor.
# Sadece eski entegrasyon kullanan harici client'lar için açın.
# AI_LEGACY_ENABLED=false

# Webhook Security (opsiyonel ama önerilir)
# Tanımlarsanız ilgili webhook endpoint'lerinde token/imza doğrulaması zorunlu olur.
# TRENDYOL_WEBHOOK_TOKEN=
# TRENDYOL_WEBHOOK_SECRET=
# N11_WEBHOOK_TOKEN=
# N11_WEBHOOK_SECRET=
# HEPSIBURADA_WEBHOOK_TOKEN=
# HEPSIBURADA_WEBHOOK_SECRET=
# CICEKSEPETI_WEBHOOK_TOKEN=
# CICEKSEPETI_WEBHOOK_SECRET=
# AMAZON_WEBHOOK_TOKEN=
# AMAZON_WEBHOOK_SECRET=
# NOON_WEBHOOK_TOKEN=
# NOON_WEBHOOK_SECRET=

# Apify — TikTok Viral Veri Çekme
APIFY_TOKEN=

# Meta — Instagram Reklam Analizi
META_AD_LIBRARY_TOKEN=

# SerpAPI — Google Trends, Amazon arama fallback (LysiaRadar)
# https://serpapi.com/manage/api_key — SERPAPI_KEY veya SERPAPI_API_KEY (ikisinden biri)
SERPAPI_KEY=
# SERPAPI_API_KEY=
# İsteğe bağlı: 429 azaltmak için ardışık istek aralığı (ms)
# SERPAPI_MIN_GAP_MS=1200

# Pinterest — Trend Projeksiyonu
PINTEREST_TOKEN=

# Amazon PA-API 5.0 — Amazon Ürün & BSR Verileri
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=

# Instagram Graph API — Hashtag Trend Verileri
INSTAGRAM_ACCESS_TOKEN=

# Gelen Kutusu — Instagram DM (Meta Business)
# https://developers.facebook.com → Uygulama → Instagram / Messenger
META_APP_ID=
META_APP_SECRET=
# OAuth callback: {BACKEND_PUBLIC_URL veya APP_URL}/api/store/inbox/instagram/oauth/callback
# Tüm kanallar için demo (Meta/Pazaryeri örnek sohbet): INBOX_DEMO=true
# INBOX_DEMO=true
# Eski ad: INBOX_IG_DEMO=true

# Gelen Kutusu — Gmail (Google Cloud Console → OAuth 2.0 → Gmail API etkin)
# Aynı GOOGLE_CLIENT_ID ile giriş yapılabilir; gelen kutu için GOOGLE_CLIENT_SECRET gerekir
# OAuth callback: {BACKEND_PUBLIC_URL}/api/store/inbox/google/oauth/callback
# GOOGLE_CLIENT_SECRET=

# TikTok Research API — Viral İçerik Analizi
TIKTOK_API_KEY=

# ─── Website Builder — Domain & SSL (F1 DNS + F2 Caddy) ───
# WB_CNAME_TARGET=sites.lysia.com.tr
# WB_APP_IP=
# WB_DOMAIN_WORKER_ENABLED=true
# WB_DOMAIN_VERIFY_INTERVAL_MS=300000
# WB_SSL_WORKER_ENABLED=true
# WB_SSL_PROVISION_INTERVAL_MS=120000
# WB_SSL_INTERNAL_SECRET=generate-long-random-secret
# WB_SSL_ALLOW_REMOTE_ASK=false
# WB_SSL_TLS_PROBE_HOST=127.0.0.1
# WB_SSL_TLS_PROBE_PORT=443
# WB_SSL_MAX_ATTEMPTS=12
# WB_SSL_RETRY_MINUTES=10
# WB_SSL_BATCH_SIZE=10
# CADDY_STORAGE_PATH=/var/lib/caddy/.local/share/caddy/certificates
# Caddy ask URL (Caddyfile): http://127.0.0.1:5000/internal/wb/ssl/authorize?domain=

# Mağaza ürün görselleri — AI düzenleme (opsiyonel, yoksa tarayıcıda işlenir)
# REMOVE_BG_API_KEY=
# CLIPDROP_API_KEY=
